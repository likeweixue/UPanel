package service

import (
	"context"
	"fmt"
	"os"
	"path/filepath"

	"github.com/docker/docker/api/types/container"
	"github.com/docker/docker/api/types/network"
	"github.com/docker/docker/client"
	"github.com/docker/go-connections/nat"
)

type Website struct {
	ID       string `json:"id"`
	Name     string `json:"name"`
	Domain   string `json:"domain"`
	Status   string `json:"status"`
	Port     int    `json:"port"`
	Created  string `json:"created"`
	PHPVersion string `json:"php_version"`
}

type CreateWebsiteRequest struct {
	Domain     string `json:"domain"`
	PHPVersion string `json:"php_version"`
	CreateDB   bool   `json:"create_db"`
	DBName     string `json:"db_name"`
	DBPassword string `json:"db_password"`
}

type WebsiteService struct {
	cli *client.Client
}

func NewWebsiteService() (*WebsiteService, error) {
	cli, err := client.NewClientWithOpts(client.FromEnv, client.WithAPIVersionNegotiation())
	if err != nil {
		return nil, err
	}
	return &WebsiteService{cli: cli}, nil
}

func (s *WebsiteService) Close() error {
	return s.cli.Close()
}

// 创建网站
func (s *WebsiteService) CreateWebsite(req *CreateWebsiteRequest) (*Website, error) {
	// 1. 创建网站目录
	siteDir := fmt.Sprintf("/Users/machangsheng/Downloads/Upanel/www/%s", req.Domain)
	if err := os.MkdirAll(filepath.Join(siteDir, "html"), 0755); err != nil {
		return nil, fmt.Errorf("创建网站目录失败: %v", err)
	}
	
	// 创建测试页面
	indexContent := fmt.Sprintf(`<?php
echo "<h1>Welcome to %s</h1>";
echo "<p>Powered by UPanel</p>";
echo "<p>PHP Version: " . phpversion() . "</p>";
?>
`, req.Domain)
	if err := os.WriteFile(filepath.Join(siteDir, "html", "index.php"), []byte(indexContent), 0644); err != nil {
		return nil, err
	}

	// 2. 创建网络
	networkName := "upanel_network"
	_, err := s.cli.NetworkInspect(context.Background(), networkName, network.InspectOptions{})
	if err != nil {
		_, err = s.cli.NetworkCreate(context.Background(), networkName, network.CreateOptions{
			Driver: "bridge",
		})
		if err != nil {
			return nil, fmt.Errorf("创建网络失败: %v", err)
		}
	}

	// 3. 创建 MySQL（如果需要）
	if req.CreateDB {
		_, err := s.createMySQL(req.Domain, req.DBName, req.DBPassword)
		if err != nil {
			return nil, err
		}
	}

	// 4. 创建 PHP-FPM
	phpContainer, err := s.createPHP(req.Domain, siteDir)
	if err != nil {
		return nil, err
	}

	// 5. 创建 Nginx
	nginxContainer, err := s.createNginx(req.Domain, siteDir, phpContainer.ID)
	if err != nil {
		return nil, err
	}

	return &Website{
		ID:         nginxContainer.ID[:12],
		Name:       req.Domain,
		Domain:     req.Domain,
		Status:     "running",
		Port:       80,
		Created:    nginxContainer.Created,
		PHPVersion: req.PHPVersion,
	}, nil
}

func (s *WebsiteService) createPHP(domain, siteDir string) (container.CreateResponse, error) {
	config := &container.Config{
		Image: "php:8.2-fpm",
		WorkingDir: "/var/www/html",
	}
	
	hostConfig := &container.HostConfig{
		Binds: []string{
			siteDir + "/html:/var/www/html",
		},
	}
	
	return s.cli.ContainerCreate(context.Background(), config, hostConfig, nil, nil, "upanel_php_"+domain)
}

func (s *WebsiteService) createNginx(domain, siteDir, phpContainerID string) (container.CreateResponse, error) {
	nginxConfig := fmt.Sprintf(`server {
    listen 80;
    server_name %s;
    root /var/www/html;
    index index.php index.html;

    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        fastcgi_pass %s:9000;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }
}`, domain, "upanel_php_"+domain)
	
	configDir := fmt.Sprintf("/tmp/nginx_%s", domain)
	os.MkdirAll(configDir, 0755)
	configFile := filepath.Join(configDir, "default.conf")
	os.WriteFile(configFile, []byte(nginxConfig), 0644)
	
	config := &container.Config{
		Image: "nginx:alpine",
		ExposedPorts: nat.PortSet{
			"80/tcp": struct{}{},
		},
	}
	
	hostConfig := &container.HostConfig{
		Binds: []string{
			siteDir + "/html:/var/www/html",
			configFile + ":/etc/nginx/conf.d/default.conf",
		},
		PortBindings: nat.PortMap{
			"80/tcp": []nat.PortBinding{{HostPort: "8081"}},
		},
	}
	
	return s.cli.ContainerCreate(context.Background(), config, hostConfig, nil, nil, "upanel_nginx_"+domain)
}

func (s *WebsiteService) createMySQL(domain, dbName, dbPassword string) (container.CreateResponse, error) {
	config := &container.Config{
		Image: "mysql:8.0",
		Env: []string{
			"MYSQL_ROOT_PASSWORD=" + dbPassword,
			"MYSQL_DATABASE=" + dbName,
		},
	}
	
	hostConfig := &container.HostConfig{}
	
	return s.cli.ContainerCreate(context.Background(), config, hostConfig, nil, nil, "upanel_mysql_"+domain)
}

func (s *WebsiteService) ListWebsites() ([]Website, error) {
	containers, err := s.cli.ContainerList(context.Background(), container.ListOptions{All: true})
	if err != nil {
		return nil, err
	}
	
	var websites []Website
	for _, c := range containers {
		if len(c.Names) > 0 && len(c.Names[0]) > 14 && c.Names[0][1:15] == "upanel_nginx_" {
			websites = append(websites, Website{
				ID:     c.ID[:12],
				Name:   c.Names[0][15:],
				Status: c.State,
			})
		}
	}
	return websites, nil
}

func (s *WebsiteService) DeleteWebsite(domain string) error {
	containers := []string{
		"upanel_nginx_" + domain,
		"upanel_php_" + domain,
		"upanel_mysql_" + domain,
	}
	
	for _, name := range containers {
		allContainers, _ := s.cli.ContainerList(context.Background(), container.ListOptions{All: true})
		for _, c := range allContainers {
			if len(c.Names) > 0 && c.Names[0] == "/"+name {
				s.cli.ContainerStop(context.Background(), c.ID, nil)
				s.cli.ContainerRemove(context.Background(), c.ID, container.RemoveOptions{Force: true})
				break
			}
		}
	}
	
	siteDir := fmt.Sprintf("/Users/machangsheng/Downloads/Upanel/www/%s", domain)
	return os.RemoveAll(siteDir)
}
