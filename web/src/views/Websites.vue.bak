<template>
  <div class="websites-container">
    <!-- 顶部分类面板 -->
    <div class="top-panel">
      <div class="top-left">
        <el-button type="primary" @click="openCreateDrawer">
          <el-icon><Plus /></el-icon> 创建网站
        </el-button>
        <el-button 
          v-if="selectedRows.length > 0" 
          type="danger" 
          plain
          @click="batchDelete"
        >
          批量删除 ({{ selectedRows.length }})
        </el-button>
        <el-button 
          v-if="selectedRows.length > 0" 
          type="success" 
          plain
          @click="batchStart"
        >
          批量启动
        </el-button>
        <el-button 
          v-if="selectedRows.length > 0" 
          type="warning" 
          plain
          @click="batchStop"
        >
          批量停止
        </el-button>
      </div>
      <div class="top-right">
        <el-input 
          v-model="searchKeyword" 
          placeholder="搜索网站" 
          prefix-icon="Search"
          clearable
          style="width: 200px"
        />
      </div>
    </div>

    <!-- 网站表格 -->
    <div class="websites-panel">
      <el-table 
        :data="filteredWebsites" 
        stripe 
        style="width: 100%"
        @selection-change="handleSelectionChange"
      >
        <el-table-column type="selection" width="55" />
        <el-table-column prop="domain" label="域名" min-width="180" />
        <el-table-column prop="phpVersion" label="类型" width="100">
          <template #default="{ row }">
            <el-tag size="small">PHP {{ row.phpVersion }}</el-tag>
          </template>
        </el-table-column>
        <el-table-column label="目录" min-width="200">
          <template #default="{ row }">
            <div class="folder-link" @click="openDirectory(row)" :title="row.path">
              <el-icon><Folder /></el-icon>
              <span>{{ row.path }}</span>
            </div>
          </template>
        </el-table-column>
        <el-table-column prop="status" label="状态" width="100">
          <template #default="{ row }">
            <span class="status-badge" :class="row.status">
              {{ row.status === 'running' ? '运行中' : '已停止' }}
            </span>
          </template>
        </el-table-column>
        <el-table-column prop="remark" label="备注" min-width="150">
          <template #default="{ row }">
            <span 
              class="remark-cell" 
              :class="{ 'remark-placeholder': !row.remark }"
              @click="editRemark(row)"
            >
              {{ row.remark || '点击添加备注' }}
            </span>
          </template>
        </el-table-column>
        <el-table-column label="操作" width="220" fixed="right">
          <template #default="{ row }">
            <el-button 
              size="small" 
              :type="row.status === 'running' ? 'warning' : 'success'"
              @click="toggleWebsite(row)"
            >
              {{ row.status === 'running' ? '停止' : '启动' }}
            </el-button>
            <el-button size="small" @click="openWebsite(row)">
              <el-icon><Link /></el-icon> 访问
            </el-button>
            <el-dropdown @command="(cmd) => handleCommand(cmd, row)">
              <el-button size="small">
                更多 <el-icon class="el-icon--right"><ArrowDown /></el-icon>
              </el-button>
              <template #dropdown>
                <el-dropdown-menu>
                  <el-dropdown-item command="edit">编辑</el-dropdown-item>
                  <el-dropdown-item command="config">配置文件</el-dropdown-item>
                  <el-dropdown-item command="logs">访问日志</el-dropdown-item>
                  <el-dropdown-item command="backup">备份</el-dropdown-item>
                  <el-dropdown-item command="delete" divided>删除</el-dropdown-item>
                </el-dropdown-menu>
              </template>
            </el-dropdown>
          </template>
        </el-table-column>
      </el-table>
    </div>

    <!-- 创建网站抽屉 -->
    <el-drawer
      v-model="createDrawerVisible"
      title="创建网站"
      direction="rtl"
      size="450px"
    >
      <div class="drawer-content">
        <el-form :model="createForm" label-width="100px" label-position="left">
          <el-form-item label="域名" required>
            <el-input v-model="createForm.domain" placeholder="例如: example.com" />
            <div class="form-tip">支持多级域名，如 test.example.com</div>
          </el-form-item>

          <el-form-item label="PHP版本">
            <el-select v-model="createForm.phpVersion" placeholder="请选择PHP版本">
              <el-option label="PHP 8.2" value="8.2" />
              <el-option label="PHP 8.1" value="8.1" />
              <el-option label="PHP 8.0" value="8.0" />
              <el-option label="PHP 7.4" value="7.4" />
              <el-option label="PHP 7.3" value="7.3" />
            </el-select>
          </el-form-item>

          <el-form-item label="数据库">
            <el-switch v-model="createForm.createDatabase" />
            <div class="form-tip" v-if="createForm.createDatabase">自动创建MySQL数据库</div>
          </el-form-item>

          <el-form-item label="数据库名" v-if="createForm.createDatabase">
            <el-input v-model="createForm.databaseName" placeholder="留空则使用域名" />
          </el-form-item>

          <el-form-item label="数据库密码" v-if="createForm.createDatabase">
            <el-input v-model="createForm.databasePassword" type="password" placeholder="留空则自动生成" />
          </el-form-item>

          <el-form-item label="备注">
            <el-input 
              v-model="createForm.remark" 
              type="textarea" 
              :rows="3"
              placeholder="可选，添加网站备注信息"
            />
          </el-form-item>
        </el-form>

        <div class="drawer-footer">
          <el-button @click="createDrawerVisible = false">取消</el-button>
          <el-button type="primary" @click="confirmCreate" :loading="creating">
            创建
          </el-button>
        </div>
      </div>
    </el-drawer>

    <!-- 编辑网站抽屉 -->
    <el-drawer
      v-model="editDrawerVisible"
      :title="`编辑网站 - ${currentEditSite?.domain}`"
      direction="rtl"
      size="600px"
    >
      <div class="drawer-content">
        <el-tabs v-model="editActiveTab">
          <!-- 基础设置 -->
          <el-tab-pane label="基础设置" name="basic">
            <el-form :model="editForm" label-width="120px" label-position="left">
              <el-form-item label="域名">
                <el-input v-model="editForm.domain" placeholder="主域名" />
              </el-form-item>
              <el-form-item label="其他域名">
                <el-select
                  v-model="editForm.otherDomains"
                  multiple
                  filterable
                  allow-create
                  default-first-option
                  placeholder="添加其他域名"
                  style="width: 100%"
                />
                <div class="form-tip">支持多个域名绑定到同一网站</div>
              </el-form-item>
              <el-form-item label="网站目录">
                <el-input v-model="editForm.rootPath">
                  <template #append>
                    <el-button @click="browseDirectory">浏览</el-button>
                  </template>
                </el-input>
                <div class="form-tip">网站文件存放的根目录</div>
              </el-form-item>
              <el-form-item label="默认文档">
                <el-input v-model="editForm.defaultIndex" placeholder="index.html,index.php" />
                <div class="form-tip">多个用逗号分隔</div>
              </el-form-item>
              <el-form-item label="PHP版本">
                <el-select v-model="editForm.phpVersion">
                  <el-option label="PHP 8.2" value="8.2" />
                  <el-option label="PHP 8.1" value="8.1" />
                  <el-option label="PHP 8.0" value="8.0" />
                  <el-option label="PHP 7.4" value="7.4" />
                </el-select>
              </el-form-item>
            </el-form>
          </el-tab-pane>

          <!-- 流量限制 -->
          <el-tab-pane label="流量限制" name="traffic">
            <el-form :model="editForm" label-width="120px">
              <el-form-item label="带宽限制">
                <el-input-number v-model="editForm.bandwidth" :min="0" /> MB/s
                <div class="form-tip">0表示不限制</div>
              </el-form-item>
              <el-form-item label="并发连接数">
                <el-input-number v-model="editForm.maxConcurrent" :min="0" />
                <div class="form-tip">0表示不限制</div>
              </el-form-item>
            </el-form>
          </el-tab-pane>

          <!-- 反向代理 -->
          <el-tab-pane label="反向代理" name="proxy">
            <el-form :model="editForm" label-width="120px">
              <el-form-item label="启用代理">
                <el-switch v-model="editForm.enableProxy" />
              </el-form-item>
              <el-form-item label="代理地址" v-if="editForm.enableProxy">
                <el-input v-model="editForm.proxyUrl" placeholder="http://127.0.0.1:8080" />
              </el-form-item>
              <el-form-item label="代理缓存" v-if="editForm.enableProxy">
                <el-switch v-model="editForm.proxyCache" />
              </el-form-item>
            </el-form>
          </el-tab-pane>

          <!-- 安全设置 -->
          <el-tab-pane label="安全设置" name="security">
            <el-form :model="editForm" label-width="120px">
              <el-form-item label="密码访问">
                <el-switch v-model="editForm.passwordAuth" />
              </el-form-item>
              <el-form-item label="用户名" v-if="editForm.passwordAuth">
                <el-input v-model="editForm.authUsername" />
              </el-form-item>
              <el-form-item label="密码" v-if="editForm.passwordAuth">
                <el-input v-model="editForm.authPassword" type="password" />
              </el-form-item>
              <el-form-item label="跨域访问">
                <el-switch v-model="editForm.cors" />
              </el-form-item>
              <el-form-item label="允许域名" v-if="editForm.cors">
                <el-input v-model="editForm.corsDomains" placeholder="* 或指定域名" />
              </el-form-item>
              <el-form-item label="防盗链">
                <el-switch v-model="editForm.antiLeech" />
              </el-form-item>
              <el-form-item label="允许域名" v-if="editForm.antiLeech">
                <el-input v-model="editForm.antiLeechDomains" placeholder="example.com" />
              </el-form-item>
            </el-form>
          </el-tab-pane>

          <!-- SSL证书 -->
          <el-tab-pane label="SSL证书" name="ssl">
            <el-form :model="editForm" label-width="120px">
              <el-form-item label="启用HTTPS">
                <el-switch v-model="editForm.enableSSL" />
              </el-form-item>
              <el-form-item label="证书类型" v-if="editForm.enableSSL">
                <el-radio-group v-model="editForm.sslType">
                  <el-radio value="lets">Let's Encrypt</el-radio>
                  <el-radio value="custom">自定义证书</el-radio>
                </el-radio-group>
              </el-form-item>
              <el-form-item label="证书文件" v-if="editForm.enableSSL && editForm.sslType === 'custom'">
                <el-input v-model="editForm.sslCert" placeholder="证书文件路径" />
              </el-form-item>
              <el-form-item label="私钥文件" v-if="editForm.enableSSL && editForm.sslType === 'custom'">
                <el-input v-model="editForm.sslKey" placeholder="私钥文件路径" />
              </el-form-item>
              <el-form-item v-if="editForm.enableSSL && editForm.sslType === 'lets'">
                <el-button type="primary" size="small">申请证书</el-button>
                <div class="form-tip">需要域名已解析到当前服务器</div>
              </el-form-item>
            </el-form>
          </el-tab-pane>

          <!-- 伪静态 -->
          <el-tab-pane label="伪静态" name="rewrite">
            <el-form :model="editForm" label-width="120px">
              <el-form-item label="规则模板">
                <el-select v-model="editForm.rewriteTemplate" placeholder="选择规则模板">
                  <el-option label="WordPress" value="wordpress" />
                  <el-option label="Discuz" value="discuz" />
                  <el-option label="Typecho" value="typecho" />
                  <el-option label="ThinkPHP" value="thinkphp" />
                  <el-option label="自定义" value="custom" />
                </el-select>
              </el-form-item>
              <el-form-item label="规则内容" v-if="editForm.rewriteTemplate === 'custom'">
                <el-input 
                  v-model="editForm.rewriteRules" 
                  type="textarea" 
                  :rows="8"
                  placeholder="location / {
    try_files $uri $uri/ /index.php?$args;
}"
                />
              </el-form-item>
            </el-form>
          </el-tab-pane>

          <!-- 负载均衡 -->
          <el-tab-pane label="负载均衡" name="loadBalance">
            <el-form :model="editForm" label-width="120px">
              <el-form-item label="启用负载均衡">
                <el-switch v-model="editForm.enableLoadBalance" />
              </el-form-item>
              <el-form-item label="后端服务器" v-if="editForm.enableLoadBalance">
                <div class="upstream-list">
                  <div v-for="(server, idx) in editForm.upstreamServers" :key="idx" class="upstream-item">
                    <el-input v-model="server.address" placeholder="127.0.0.1:8080" style="flex:1" />
                    <el-input-number v-model="server.weight" :min="1" :max="100" style="width:100px" />
                    <el-button type="danger" @click="removeUpstream(idx)">删除</el-button>
                  </div>
                  <el-button type="primary" size="small" @click="addUpstream">添加服务器</el-button>
                </div>
                <div class="form-tip">权重越高，分配的请求越多</div>
              </el-form-item>
            </el-form>
          </el-tab-pane>
        </el-tabs>

        <div class="drawer-footer">
          <el-button @click="editDrawerVisible = false">取消</el-button>
          <el-button type="primary" @click="saveEdit" :loading="saving">
            保存设置
          </el-button>
        </div>
      </div>
    </el-drawer>

    <!-- 备份抽屉 -->
    <el-drawer
      v-model="backupDrawerVisible"
      title="网站备份"
      direction="rtl"
      size="400px"
    >
      <div class="drawer-content">
        <div class="backup-info">
          <div class="backup-site">{{ currentBackupSite?.domain }}</div>
          <div class="backup-path">{{ currentBackupSite?.path }}</div>
        </div>
        
        <el-form label-width="100px" label-position="left">
          <el-form-item label="备份类型">
            <el-radio-group v-model="backupType">
              <el-radio value="full">完整备份</el-radio>
              <el-radio value="files">仅文件</el-radio>
              <el-radio value="database">仅数据库</el-radio>
            </el-radio-group>
          </el-form-item>

          <el-form-item label="备份名称">
            <el-input v-model="backupName" placeholder="留空则自动生成" />
          </el-form-item>

          <el-form-item label="备注">
            <el-input 
              v-model="backupRemark" 
              type="textarea" 
              :rows="3"
              placeholder="可选"
            />
          </el-form-item>
        </el-form>

        <div class="backup-list" v-if="backupList.length">
          <div class="backup-list-title">已有备份</div>
          <div class="backup-items">
            <div v-for="item in backupList" :key="item.id" class="backup-item">
              <div class="backup-item-info">
                <div class="backup-item-name">{{ item.name }}</div>
                <div class="backup-item-time">{{ item.time }}</div>
              </div>
              <div class="backup-item-actions">
                <el-button size="small" @click="downloadBackup(item)">下载</el-button>
                <el-button size="small" type="danger" @click="deleteBackup(item)">删除</el-button>
              </div>
            </div>
          </div>
        </div>

        <div class="drawer-footer">
          <el-button @click="backupDrawerVisible = false">取消</el-button>
          <el-button type="primary" @click="confirmBackup" :loading="backingUp">
            开始备份
          </el-button>
        </div>
      </div>
    </el-drawer>

    <!-- 备注编辑对话框 -->
    <el-dialog v-model="remarkDialogVisible" title="编辑备注" width="400px">
      <el-input 
        v-model="editingRemark" 
        type="textarea" 
        :rows="4"
        placeholder="请输入备注信息"
      />
      <template #footer>
        <el-button @click="remarkDialogVisible = false">取消</el-button>
        <el-button type="primary" @click="saveRemark">保存</el-button>
      </template>
    </el-dialog>
  </div>
</template>

<script setup>
import { ref, computed } from 'vue'
import { ElMessage, ElMessageBox } from 'element-plus'
import { Plus, Link, ArrowDown, Folder } from '@element-plus/icons-vue'

const searchKeyword = ref('')
const createDrawerVisible = ref(false)
const editDrawerVisible = ref(false)
const backupDrawerVisible = ref(false)
const creating = ref(false)
const saving = ref(false)
const backingUp = ref(false)
const remarkDialogVisible = ref(false)
const editingRemark = ref('')
const currentWebsite = ref(null)
const currentEditSite = ref(null)
const currentBackupSite = ref(null)
const selectedRows = ref([])
const editActiveTab = ref('basic')

// 备份相关
const backupType = ref('full')
const backupName = ref('')
const backupRemark = ref('')
const backupList = ref([])

// 编辑表单
const editForm = ref({
  domain: '',
  otherDomains: [],
  rootPath: '',
  defaultIndex: 'index.html,index.php',
  phpVersion: '8.2',
  bandwidth: 0,
  maxConcurrent: 0,
  enableProxy: false,
  proxyUrl: '',
  proxyCache: false,
  passwordAuth: false,
  authUsername: '',
  authPassword: '',
  cors: false,
  corsDomains: '*',
  antiLeech: false,
  antiLeechDomains: '',
  enableSSL: false,
  sslType: 'lets',
  sslCert: '',
  sslKey: '',
  rewriteTemplate: '',
  rewriteRules: '',
  enableLoadBalance: false,
  upstreamServers: []
})

const createForm = ref({
  domain: '',
  phpVersion: '8.2',
  createDatabase: false,
  databaseName: '',
  databasePassword: '',
  remark: ''
})

const websites = ref([
  {
    id: 1,
    domain: 'example.com',
    phpVersion: '8.2',
    path: '/www/wwwroot/example.com',
    status: 'running',
    remark: '主站',
    createdAt: '2024-01-15'
  },
  {
    id: 2,
    domain: 'test.local',
    phpVersion: '8.1',
    path: '/www/wwwroot/test.local',
    status: 'stopped',
    remark: '',
    createdAt: '2024-01-20'
  },
  {
    id: 3,
    domain: 'blog.example.com',
    phpVersion: '7.4',
    path: '/www/wwwroot/blog.example.com',
    status: 'running',
    remark: '技术博客',
    createdAt: '2024-02-01'
  }
])

const filteredWebsites = computed(() => {
  if (!searchKeyword.value) return websites.value
  return websites.value.filter(site => 
    site.domain.toLowerCase().includes(searchKeyword.value.toLowerCase())
  )
})

const handleSelectionChange = (selection) => {
  selectedRows.value = selection
}

const batchDelete = async () => {
  await ElMessageBox.confirm(`确定删除选中的 ${selectedRows.value.length} 个网站吗？`, '警告', {
    confirmButtonText: '确定',
    cancelButtonText: '取消',
    type: 'warning'
  })
  
  selectedRows.value.forEach(row => {
    const index = websites.value.findIndex(w => w.id === row.id)
    if (index !== -1) {
      websites.value.splice(index, 1)
    }
  })
  ElMessage.success('批量删除成功')
}

const batchStart = async () => {
  for (const row of selectedRows.value) {
    if (row.status !== 'running') {
      row.status = 'running'
    }
  }
  ElMessage.success(`已启动 ${selectedRows.value.length} 个网站`)
}

const batchStop = async () => {
  for (const row of selectedRows.value) {
    if (row.status === 'running') {
      row.status = 'stopped'
    }
  }
  ElMessage.success(`已停止 ${selectedRows.value.length} 个网站`)
}

const openCreateDrawer = () => {
  createForm.value = {
    domain: '',
    phpVersion: '8.2',
    createDatabase: false,
    databaseName: '',
    databasePassword: '',
    remark: ''
  }
  createDrawerVisible.value = true
}

const confirmCreate = async () => {
  if (!createForm.value.domain) {
    ElMessage.warning('请输入域名')
    return
  }
  
  creating.value = true
  try {
    const newWebsite = {
      id: Date.now(),
      domain: createForm.value.domain,
      phpVersion: createForm.value.phpVersion,
      path: `/www/wwwroot/${createForm.value.domain}`,
      status: 'running',
      remark: createForm.value.remark || '',
      createdAt: new Date().toISOString().split('T')[0]
    }
    
    await new Promise(resolve => setTimeout(resolve, 1000))
    websites.value.unshift(newWebsite)
    ElMessage.success('网站创建成功')
    createDrawerVisible.value = false
  } catch (err) {
    ElMessage.error('创建失败: ' + err.message)
  } finally {
    creating.value = false
  }
}

const openEditDrawer = (website) => {
  currentEditSite.value = website
  editForm.value = {
    domain: website.domain,
    otherDomains: [],
    rootPath: website.path,
    defaultIndex: 'index.html,index.php',
    phpVersion: website.phpVersion,
    bandwidth: 0,
    maxConcurrent: 0,
    enableProxy: false,
    proxyUrl: '',
    proxyCache: false,
    passwordAuth: false,
    authUsername: '',
    authPassword: '',
    cors: false,
    corsDomains: '*',
    antiLeech: false,
    antiLeechDomains: '',
    enableSSL: false,
    sslType: 'lets',
    sslCert: '',
    sslKey: '',
    rewriteTemplate: '',
    rewriteRules: '',
    enableLoadBalance: false,
    upstreamServers: []
  }
  editActiveTab.value = 'basic'
  editDrawerVisible.value = true
}

const saveEdit = async () => {
  saving.value = true
  try {
    await new Promise(resolve => setTimeout(resolve, 1000))
    if (currentEditSite.value) {
      currentEditSite.value.domain = editForm.value.domain
      currentEditSite.value.phpVersion = editForm.value.phpVersion
      currentEditSite.value.path = editForm.value.rootPath
    }
    ElMessage.success('保存成功')
    editDrawerVisible.value = false
  } catch (err) {
    ElMessage.error('保存失败: ' + err.message)
  } finally {
    saving.value = false
  }
}

const addUpstream = () => {
  editForm.value.upstreamServers.push({ address: '', weight: 1 })
}

const removeUpstream = (index) => {
  editForm.value.upstreamServers.splice(index, 1)
}

const browseDirectory = () => {
  ElMessage.info('目录浏览器开发中')
}

const toggleWebsite = async (website) => {
  try {
    await new Promise(resolve => setTimeout(resolve, 500))
    website.status = website.status === 'running' ? 'stopped' : 'running'
    ElMessage.success(`网站已${website.status === 'running' ? '启动' : '停止'}`)
  } catch (err) {
    ElMessage.error('操作失败: ' + err.message)
  }
}

const openWebsite = (website) => {
  if (website.status !== 'running') {
    ElMessage.warning('网站未运行，请先启动')
    return
  }
  window.open(`http://${website.domain}`, '_blank')
}

const openDirectory = (website) => {
  ElMessage.info(`跳转到 ${website.path}`)
}

const editRemark = (website) => {
  currentWebsite.value = website
  editingRemark.value = website.remark || ''
  remarkDialogVisible.value = true
}

const saveRemark = () => {
  if (currentWebsite.value) {
    currentWebsite.value.remark = editingRemark.value
    ElMessage.success('备注已更新')
  }
  remarkDialogVisible.value = false
}

const openBackupDrawer = (website) => {
  currentBackupSite.value = website
  backupType.value = 'full'
  backupName.value = ''
  backupRemark.value = ''
  backupList.value = [
    { id: 1, name: 'backup_20240115.tar.gz', time: '2024-01-15 10:30' },
    { id: 2, name: 'backup_20240120.tar.gz', time: '2024-01-20 14:20' }
  ]
  backupDrawerVisible.value = true
}

const confirmBackup = async () => {
  backingUp.value = true
  try {
    await new Promise(resolve => setTimeout(resolve, 2000))
    ElMessage.success('备份创建成功')
    backupDrawerVisible.value = false
  } catch (err) {
    ElMessage.error('备份失败: ' + err.message)
  } finally {
    backingUp.value = false
  }
}

const downloadBackup = (item) => {
  ElMessage.info(`下载 ${item.name}`)
}

const deleteBackup = async (item) => {
  await ElMessageBox.confirm(`确定删除备份 ${item.name} 吗？`, '警告', {
    confirmButtonText: '确定',
    cancelButtonText: '取消',
    type: 'warning'
  })
  const index = backupList.value.findIndex(b => b.id === item.id)
  if (index !== -1) {
    backupList.value.splice(index, 1)
    ElMessage.success('备份已删除')
  }
}

const handleCommand = (command, website) => {
  switch (command) {
    case 'edit':
      openEditDrawer(website)
      break
    case 'config':
      ElMessage.info('配置文件功能开发中')
      break
    case 'logs':
      ElMessage.info('日志查看功能开发中')
      break
    case 'backup':
      openBackupDrawer(website)
      break
    case 'delete':
      ElMessageBox.confirm(`确定删除网站 ${website.domain} 吗？`, '警告', {
        confirmButtonText: '确定',
        cancelButtonText: '取消',
        type: 'warning'
      }).then(async () => {
        const index = websites.value.findIndex(w => w.id === website.id)
        if (index !== -1) {
          websites.value.splice(index, 1)
          ElMessage.success('网站已删除')
        }
      }).catch(() => {})
      break
  }
}
</script>

